# Uygulama
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paylaşım şifresi çerezi imzası (en az 16 karakter rastgele)
SHARE_UNLOCK_SECRET=

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Neon veya başka Postgres — Drizzle push için
DATABASE_URL=

# OpenAI — Whisper transcript (https://platform.openai.com)
OPENAI_API_KEY=
# İsteğe bağlı: ISO-639-1 (örn. tr) — boş bırakılırsa otomatik algı
TRANSCRIPT_DEFAULT_LANGUAGE=

# Masaüstü / API istemcisi — POST /api/mux/upload: tarayıcı oturumu, veya Authorization: Bearer <Clerk JWT>,
# veya (geliştirici) x-promptly-desktop-key + aşağıdaki owner id
DESKTOP_APIKEY=
DESKTOP_OWNER_CLERK_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx
# Bearer doğrulaması için izinli origin’ler (boşsa NEXT_PUBLIC_APP_URL)
# CLERK_AUTHORIZED_PARTIES=http://localhost:3000,https://your-app.vercel.app

# Mux — https://dashboard.mux.com
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
# Tarayıcıdan PUT yükleme için origin (production'da tam URL, örn. https://app.promptly.example)
MUX_CORS_ORIGIN=http://localhost:3000
